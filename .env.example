# Environment: development, production
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=db
DB_PORT=3306
DB_NAME=elyon360
DB_USER=elyon_user
DB_PASSWORD=elyon_pass
DB_ROOT_PASSWORD=rootpassword
